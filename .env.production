# ==============================================================================
# TRINETRA AI - PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env' on your production server: cp .env.production .env
# 2. Update all credentials, endpoints, secrets, and CORS origins.
# 3. Disables FastAPI and Vite debug mode for maximum performance and security.

# ------------------------------------------------------------------------------
# 1. Global App Configuration
# ------------------------------------------------------------------------------
APP_NAME=TRINETRA AI
APP_VERSION=1.2.0
DEBUG=false

# ------------------------------------------------------------------------------
# 2. Backend Server Settings
# ------------------------------------------------------------------------------
# 0.0.0.0 binds to all interfaces for production hosting inside Docker / VMs
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ------------------------------------------------------------------------------
# 3. Production Databases (PostgreSQL & Redis)
# ------------------------------------------------------------------------------
# Update postgres credentials and host address (e.g. your cloud DB address)
DATABASE_URL=postgresql://trinetra_prod_user:trinetra_secure_password_9876@postgres_host:5432/trinetra_prod_db
REDIS_URL=redis://redis_host:6379/0

# ------------------------------------------------------------------------------
# 4. Object Storage (MinIO / S3)
# ------------------------------------------------------------------------------
# Object storage endpoint URL for persistent evidence uploads.
MINIO_URL=http://minio_host:9000
MINIO_ACCESS_KEY=trinetra_prod_minio_admin
MINIO_SECRET_KEY=trinetra_prod_minio_secret_key_change_me
MINIO_BUCKET=trinetra-evidence

# ------------------------------------------------------------------------------
# 5. Security & Authentication
# ------------------------------------------------------------------------------
# CRITICAL: Generate a strong secret key using: openssl rand -hex 32
SECRET_KEY=e8f9611f7c5e2d67a1029c78201a09d3bdf5c1b63e8a4a350d7e4811df6efbc9
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------------------
# 6. Machine Learning Pipeline Settings
# ------------------------------------------------------------------------------
MODEL_PATH=backend/models/best.pt
# CUDA GPU acceleration is highly recommended for production inference workloads
DEVICE=cuda

# ------------------------------------------------------------------------------
# 7. Frontend Deployment Configuration
# ------------------------------------------------------------------------------
# Limit CORS origins to your production frontend domain or load balancer IP
FRONTEND_URL=http://your-production-domain.com
VITE_API_URL=http://your-production-domain.com/api/v1

# ------------------------------------------------------------------------------
# 8. Logs and Storage Paths
# ------------------------------------------------------------------------------
DATA_DIR=data
LOGS_DIR=logs
